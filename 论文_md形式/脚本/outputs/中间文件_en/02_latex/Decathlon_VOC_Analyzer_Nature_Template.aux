\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Aspect-to-question planning. Aspect objects are not directly used as retrieval queries; they are decomposed into intent-specific questions that trigger text, image, or cross-modal evidence routes.}}{7}{figure.2}\protected@file@percent }
